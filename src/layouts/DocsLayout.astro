---
export interface Props {
  title: string;
  description?: string;
  activeNav?: string;
}

const { title, description = "Plug & Play Security for FastAPI", activeNav = "" } = Astro.props;

const navSections = [
  {
    label: "Getting Started",
    items: [
      { href: "/", icon: "rocket_launch", label: "Introduction", id: "introduction" },
      { href: "/whats-new", icon: "new_releases", label: "What's New (v0.12)", id: "whats-new" },
    ],
  },
  {
    label: "Security Modules",
    items: [
      { href: "/webauthn-passkeys", icon: "passkey", label: "WebAuthn / Passkeys", id: "webauthn-passkeys" },
      { href: "/rate-limiting", icon: "traffic", label: "Rate Limiting", id: "rate-limiting" },
      { href: "/brute-force-protection", icon: "lock_reset", label: "Brute Force Protection", id: "brute-force-protection" },
      { href: "/honeypot", icon: "humidity_mid", label: "Honeypot Endpoints", id: "honeypot" },
      { href: "/api-keys", icon: "vpn_key", label: "API Keys", id: "api-keys" },
      { href: "/jwt-auth", icon: "confirmation_number", label: "JWT & Token Rotation", id: "jwt-auth" },
      { href: "/malware-scanning", icon: "bug_report", label: "Malware Scanning", id: "malware-scanning" },
      { href: "/prompt-injection", icon: "smart_toy", label: "Prompt Injection Detection", id: "prompt-injection" },
      { href: "/csrf-protection", icon: "cookie", label: "CSRF Protection", id: "csrf-protection" },
      { href: "/session-management", icon: "groups", label: "Session Management", id: "session-management" },
      { href: "/sanitization", icon: "cleaning_services", label: "Sanitization", id: "sanitization" },
      { href: "/secure-headers", icon: "shield", label: "Secure Headers", id: "secure-headers" },
      { href: "/cors-policy", icon: "language", label: "CORS Policy", id: "cors-policy" },
      { href: "/ip-access-control", icon: "block", label: "IP Access Control", id: "ip-access-control" },
      { href: "/audit-logging", icon: "list_alt", label: "Audit Logging", id: "audit-logging" },
    ],
  },
  {
    label: "Observability",
    items: [
      { href: "/opentelemetry", icon: "timeline", label: "OpenTelemetry", id: "opentelemetry" },
      { href: "/prometheus-metrics", icon: "monitoring", label: "Prometheus Metrics", id: "prometheus-metrics" },
      { href: "/security-webhooks", icon: "webhook", label: "Security Webhooks", id: "security-webhooks" },
    ],
  },
  {
    label: "Infrastructure",
    items: [
      { href: "/redis-sentinel-cluster", icon: "dns", label: "Redis Sentinel & Cluster", id: "redis-sentinel-cluster" },
    ],
  },
  {
    label: "Tools",
    items: [
      { href: "/cli", icon: "terminal", label: "Araxys CLI", id: "cli" },
      { href: "/configuration", icon: "settings", label: "Configuration", id: "configuration" },
    ],
  },
];
---

<!DOCTYPE html>
<html lang="en" class="dark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title} — Araxys Docs</title>
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png?v=2" />
  <link rel="icon" type="image/png" sizes="16x16" href="/favicon-32x32.png?v=2" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200&display=swap" />
</head>
<body class="min-h-screen">
  <!-- Mobile overlay -->
  <div id="mobile-overlay" class="fixed inset-0 bg-black/60 z-40 hidden lg:hidden backdrop-blur-sm" aria-hidden="true"></div>

  <!-- Header -->
  <header class="fixed top-0 left-0 right-0 z-30 h-14 flex items-center justify-between px-4 lg:px-6 border-b border-surface-stroke bg-surface/80 backdrop-blur-md" data-pagefind-ignore>
    <div class="flex items-center gap-3">
      <!-- Mobile hamburger -->
      <button id="mobile-toggle" class="lg:hidden p-1.5 rounded-md hover:bg-surface-high transition-colors" aria-label="Toggle navigation">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
      <a href="/" class="flex items-center gap-2.5">
        <img src="/araxyslogo-nobg.png" alt="Araxys" class="h-12 w-auto logo-invert" />
        <span class="font-semibold text-text-primary text-[15px] tracking-tight" style="font-family: var(--font-headline)">Araxys</span>
      </a>
      <span class="label-sm text-text-muted bg-surface-high px-2 py-0.5 rounded-sm hidden sm:inline-block">v0.12.0</span>
    </div>

    <div class="flex items-center gap-3">
      <!-- Search bar -->
      <div class="hidden md:flex items-center gap-2 bg-surface-container border border-surface-stroke rounded-full px-4 py-1.5 w-64 cursor-pointer hover:border-surface-bright transition-colors" id="search-trigger">
        <svg class="w-4 h-4 text-text-muted" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
        </svg>
        <span class="text-sm text-text-muted flex-1">Search docs...</span>
        <kbd class="text-[11px] font-medium text-text-muted bg-surface-high border border-surface-stroke rounded px-1.5 py-0.5" style="font-family: var(--font-code)">⌘K</kbd>
      </div>

      <!-- GitHub link -->
      <a href="https://github.com/Samuel-Urrego/Araxys" target="_blank" rel="noopener" class="p-1.5 rounded-md text-text-muted hover:text-text-primary hover:bg-surface-high transition-colors" aria-label="View on GitHub">
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
          <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd" />
        </svg>
      </a>
    </div>
  </header>

  <!-- Main layout -->
  <div class="flex pt-14">
    <!-- Left sidebar -->
    <nav id="nav-sidebar" class="nav-sidebar fixed top-14 left-0 bottom-0 w-[280px] bg-surface border-r border-surface-stroke overflow-y-auto py-6 px-4 hidden lg:block z-50" data-pagefind-ignore>
      {navSections.map((section) => (
        <div class="mb-6">
          <div class="label-sm text-text-muted mb-3 px-2">{section.label}</div>
          <ul class="space-y-0.5">
            {section.items.map((item) => (
              <li>
                <a
                  href={item.href}
                  class:list={[
                    "flex items-center gap-2.5 px-2 py-2 rounded-md text-sm transition-all duration-200 group relative",
                    activeNav === item.id
                      ? "text-primary bg-primary/5 font-medium"
                      : "text-text-secondary hover:text-text-primary hover:bg-surface-high",
                  ]}
                >
                  {activeNav === item.id && (
                    <span class="absolute left-0 top-1/2 -translate-y-1/2 w-0.5 h-5 bg-primary rounded-full" />
                  )}
                  <span class="material-symbols-outlined text-[18px]">{item.icon}</span>
                  <span>{item.label}</span>
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}

      <!-- Sidebar footer -->
      <div class="mt-8 pt-4 border-t border-surface-stroke px-2">
        <a href="https://github.com/Samuel-Urrego/Araxys" target="_blank" rel="noopener" class="flex items-center gap-2 text-xs text-text-muted hover:text-text-primary transition-colors">
          <span>View on GitHub</span>
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
          </svg>
        </a>
      </div>
    </nav>

    <!-- Content area -->
    <main class="flex-1 lg:ml-[280px] min-h-[calc(100vh-3.5rem)]">
      <div class="max-w-6xl mx-auto flex">
        <!-- Main content -->
        <div class="flex-1 max-w-[820px] mx-auto px-6 lg:px-8 py-8 lg:py-12">
          <article class="prose" data-pagefind-body>
            <slot />
          </article>

          <!-- Page footer -->
          <footer class="mt-16 pt-6 border-t border-surface-stroke">
            <div class="flex items-center justify-between text-xs text-text-muted">
              <span>Built with <span class="material-symbols-outlined text-[12px] align-middle text-primary">shield</span> by <a href="https://github.com/Samuel-Urrego/Araxys" class="text-primary-soft hover:underline">Samuel Esteban Urrego Valencia</a></span>
              <span>MIT License</span>
            </div>
          </footer>
        </div>

        <!-- Right sidebar: Table of Contents -->
        <aside id="toc-sidebar" class="toc-sidebar hidden xl:block w-[240px] flex-shrink-0 sticky top-14 h-[calc(100vh-3.5rem)] overflow-y-auto py-8 pr-6" data-pagefind-ignore>
          <div class="label-sm text-text-muted mb-4">On this page</div>
          <nav id="toc-nav" class="space-y-1">
            <!-- TOC items populated by JS -->
          </nav>
        </aside>
      </div>
    </main>
  </div>

  <!-- Search Modal -->
  <div id="search-modal" class="fixed inset-0 z-[60] hidden flex items-start justify-center pt-[15vh] px-4">
    <div class="fixed inset-0 bg-black/80 backdrop-blur-sm" id="search-close"></div>
    <div class="relative w-full max-w-2xl bg-surface-container border border-surface-stroke rounded-xl shadow-2xl overflow-hidden animate-in fade-in zoom-in duration-200">
      <div class="flex items-center gap-3 p-4 border-b border-surface-stroke bg-surface-high/50">
        <svg class="w-5 h-5 text-text-muted" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
        </svg>
        <input 
          type="text" 
          id="search-input" 
          placeholder="Search documentation..." 
          class="flex-1 bg-transparent border-none text-text-primary placeholder:text-text-muted focus:ring-0 text-lg outline-none"
          autocomplete="off"
        />
        <kbd class="text-[11px] font-medium text-text-muted bg-surface-low border border-surface-stroke rounded px-1.5 py-0.5" style="font-family: var(--font-code)">ESC</kbd>
      </div>
      <div id="search-results" class="max-h-[60vh] overflow-y-auto p-2 empty:hidden">
        <!-- Results will be injected here -->
      </div>
      <div id="search-empty" class="p-12 text-center hidden">
        <div class="text-text-muted mb-2">No results found for "<span id="search-query-display" class="text-text-primary italic"></span>"</div>
        <p class="text-xs text-text-muted">Try searching for different keywords or module names.</p>
      </div>
      <div class="p-3 bg-surface border-t border-surface-stroke flex items-center justify-between text-[11px] text-text-muted">
        <div class="flex items-center gap-4">
          <span class="flex items-center gap-1"><kbd class="bg-surface-high px-1 rounded">↑↓</kbd> Navigate</span>
          <span class="flex items-center gap-1"><kbd class="bg-surface-high px-1 rounded">↵</kbd> Select</span>
        </div>
        <div class="flex items-center gap-1">
          Search by <span class="font-semibold text-text-secondary">Pagefind</span>
        </div>
      </div>
    </div>
  </div>

  <style is:global>
    /* Search result styling */
    .pagefind-result {
      display: block;
      padding: 0.75rem 1rem;
      border-radius: 0.5rem;
      transition: all 0.2s ease;
      cursor: pointer;
    }
    .pagefind-result:hover, .pagefind-result.active {
      background-color: var(--color-surface-high);
    }
    .pagefind-result-title {
      font-weight: 600;
      color: var(--color-text-primary);
      margin-bottom: 0.25rem;
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }
    .pagefind-result-excerpt {
      font-size: 0.85rem;
      color: var(--color-text-secondary);
      line-height: 1.4;
    }
    .pagefind-result-excerpt mark {
      background-color: color-mix(in srgb, var(--color-primary) 30%, transparent);
      color: var(--color-primary-soft);
      font-weight: 500;
      border-radius: 2px;
      padding: 0 2px;
    }
  </style>

  <script>
    // --- Search Logic & Pagefind Integration ---
    let pagefind: any;
    const searchModal = document.getElementById('search-modal');
    const searchInput = document.getElementById('search-input') as HTMLInputElement;
    const searchResults = document.getElementById('search-results');
    const searchEmpty = document.getElementById('search-empty');
    const searchQueryDisplay = document.getElementById('search-query-display');
    const searchTrigger = document.getElementById('search-trigger');
    const searchClose = document.getElementById('search-close');

    async function initPagefind() {
      if (pagefind) return;
      try {
        const path = "/pagefind/pagefind.js";
        // @ts-ignore
        pagefind = await import(/* @vite-ignore */ path);
        await pagefind.init();
      } catch (e) {
        console.warn("Pagefind not found. Search will be unavailable in dev mode. Run build to test search.");
      }
    }

    function openSearch() {
      searchModal?.classList.remove('hidden');
      searchInput?.focus();
      document.body.style.overflow = 'hidden';
      initPagefind();
    }

    function closeSearch() {
      searchModal?.classList.add('hidden');
      document.body.style.overflow = '';
    }

    searchTrigger?.addEventListener('click', openSearch);
    searchClose?.addEventListener('click', closeSearch);

    document.addEventListener('keydown', (e) => {
      if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
        e.preventDefault();
        openSearch();
      }
      if (e.key === 'Escape') {
        closeSearch();
      }
    });

    let debounceTimer: any;
    searchInput?.addEventListener('input', (e) => {
      const query = (e.target as HTMLInputElement).value;
      clearTimeout(debounceTimer);
      debounceTimer = setTimeout(() => performSearch(query), 150);
    });

    async function performSearch(query: string) {
      if (!query || !pagefind || !searchResults || !searchEmpty || !searchQueryDisplay) {
        if (searchResults) searchResults.innerHTML = '';
        searchEmpty?.classList.add('hidden');
        return;
      }

      const search = await pagefind.search(query);
      const results = await Promise.all(search.results.slice(0, 8).map((r: any) => r.data()));

      searchResults.innerHTML = '';
      
      if (results.length === 0) {
        searchEmpty.classList.remove('hidden');
        searchQueryDisplay.textContent = query;
        return;
      }

      searchEmpty.classList.add('hidden');

      results.forEach((data: any) => {
        const resultItem = document.createElement('a');
        resultItem.href = data.url;
        resultItem.className = 'pagefind-result';
        resultItem.innerHTML = `
          <div class="pagefind-result-title">
            <span class="text-primary-soft">#</span>
            ${data.meta.title}
          </div>
          <div class="pagefind-result-excerpt">${data.excerpt}</div>
        `;
        searchResults.appendChild(resultItem);
      });
    }

    // --- Mobile Navigation ---
    const toggle = document.getElementById('mobile-toggle');
    const sidebar = document.getElementById('nav-sidebar');
    const overlay = document.getElementById('mobile-overlay');

    function openSidebar() {
      sidebar?.classList.add('open');
      sidebar?.classList.remove('hidden');
      overlay?.classList.remove('hidden');
      document.body.style.overflow = 'hidden';
    }

    function closeSidebar() {
      sidebar?.classList.remove('open');
      overlay?.classList.add('hidden');
      document.body.style.overflow = '';
      // On mobile, re-hide after transition
      if (window.innerWidth < 1024) {
        setTimeout(() => sidebar?.classList.add('hidden'), 300);
      }
    }

    toggle?.addEventListener('click', () => {
      if (sidebar?.classList.contains('open')) {
        closeSidebar();
      } else {
        openSidebar();
      }
    });

    overlay?.addEventListener('click', closeSidebar);

    // --- TOC Generation ---
    function generateTOC() {
      const tocNav = document.getElementById('toc-nav');
      const headings = document.querySelectorAll('.prose h2, .prose h3');
      if (!tocNav || headings.length === 0) return;

      tocNav.innerHTML = '';
      headings.forEach((h) => {
        if (!h.id) {
          h.id = h.textContent?.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '') || '';
        }
        const link = document.createElement('a');
        link.href = `#${h.id}`;
        link.textContent = h.textContent || '';
        link.className = `block text-sm py-1 transition-colors duration-200 ${
          h.tagName === 'H3' ? 'pl-4 text-text-muted hover:text-text-secondary' : 'text-text-secondary hover:text-text-primary'
        }`;
        link.dataset.target = h.id;
        tocNav.appendChild(link);
      });

      // Scroll spy
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              document.querySelectorAll('#toc-nav a').forEach((a) => {
                a.classList.remove('text-primary', '!text-primary', 'font-medium');
                if (a.tagName === 'A') {
                  const el = a as HTMLAnchorElement;
                  if (el.dataset.target === entry.target.id) {
                    el.classList.add('!text-primary', 'font-medium');
                  }
                }
              });
            }
          });
        },
        { rootMargin: '-80px 0px -60% 0px', threshold: 0 }
      );

      headings.forEach((h) => observer.observe(h));
    }

    generateTOC();

    // --- Copy to clipboard ---
    document.querySelectorAll('.code-block-copy').forEach((btn) => {
      btn.addEventListener('click', async () => {
        const code = btn.closest('.code-block')?.querySelector('pre code');
        if (!code) return;
        try {
          await navigator.clipboard.writeText(code.textContent || '');
          btn.classList.add('copied');
          btn.textContent = '✓ Copied';
          setTimeout(() => {
            btn.classList.remove('copied');
            btn.textContent = 'Copy';
          }, 2000);
        } catch {}
      });
    });

    // --- CMD+K search shortcut ---
    document.addEventListener('keydown', (e) => {
      if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
        e.preventDefault();
        document.getElementById('search-trigger')?.focus();
      }
    });
  </script>
</body>
</html>
